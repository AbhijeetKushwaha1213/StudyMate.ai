// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Resource {
  id          String   @id @default(cuid())
  userId      String
  title     String
  description String?
  type        String
  noteContent String?
  linkUrl     String?
  fileUrl     String?
  storagePath String?
  folder      String?
  tagsJson    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("resources")
}
